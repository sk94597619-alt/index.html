<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aiverse Pro (Final)</title>
  <style>
    :root{
      --bg:#0b1020; --card:#121a33; --muted:#9fb0ff; --text:#eaf0ff;
      --accent:#6ea8ff; --ok:#3ddc97; --warn:#ffcc66; --border:#243056;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Apple SD Gothic Neo,Pretendard,sans-serif;
      background:linear-gradient(180deg,#0a0f1f,#0c1430);
      color:var(--text);
    }
    .wrap{max-width:1000px; margin:0 auto; padding:20px}
    h1{margin:0 0 8px; font-size:28px}
    .sub{color:var(--muted); margin-bottom:18px}
    .topnote{
      border:1px solid #3d4b78; background:#111937; padding:10px; border-radius:10px;
      margin-bottom:12px; color:#c5d2ff; font-size:13px;
    }
    .grid{display:grid; grid-template-columns:1fr; gap:14px}
    @media (min-width:900px){ .grid{grid-template-columns:1fr 1fr} }

    .card{
      background:rgba(18,26,51,.9);
      border:1px solid var(--border);
      border-radius:14px;
      padding:14px;
      box-shadow:0 8px 28px rgba(0,0,0,.25);
    }
    .card h2{margin:0 0 10px; font-size:18px}
    label{display:block; margin:10px 0 6px; color:#cdd8ff; font-size:13px}
    textarea,select{
      width:100%;
      background:#0d152d; color:var(--text);
      border:1px solid #2a3766; border-radius:10px;
      padding:10px 12px; font-size:14px; outline:none;
    }
    textarea{min-height:110px; resize:vertical}
    .row{display:flex; gap:10px}
    .row > *{flex:1}
    button{
      background:linear-gradient(135deg,#6ea8ff,#8a7dff);
      color:white; border:none; border-radius:10px;
      padding:10px 14px; cursor:pointer; font-weight:700;
    }
    button.secondary{background:#22325f}
    button:disabled{opacity:.6; cursor:not-allowed}
    .out{
      white-space:pre-wrap;
      background:#0b1329; border:1px solid #27345f;
      border-radius:10px; padding:12px; min-height:80px; line-height:1.5;
    }
    .muted{color:var(--muted); font-size:13px}
    .status{font-size:13px; margin-top:8px}
    .ok{color:var(--ok)} .warn{color:var(--warn)}
    .img-wrap{display:grid; gap:10px}
    .img-wrap img{
      width:100%; border-radius:12px;
      border:1px solid #2c3a68; background:#0b1329;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>🤖 Aiverse Pro</h1>
    <div class="sub">이미지 생성 + 자료 요약/정리</div>
    <div class="topnote">🔒 API 키는 브라우저에 저장하지 않고 Cloudflare Worker Secret에서만 사용합니다.</div>

    <div class="grid" style="margin-top:14px">
      <div class="card">
        <h2>📚 자료 요약/정리</h2>

        <label for="sumMode">정리 방식</label>
        <select id="sumMode">
          <option value="short">짧게 요약</option>
          <option value="bullet">핵심 bullet 정리</option>
          <option value="report">리포트 형태(배경/핵심/시사점/실행)</option>
        </select>

        <label for="sumInput">원문 텍스트</label>
        <textarea id="sumInput" placeholder="기사, 회의록, 문서를 붙여넣으세요."></textarea>

        <div class="row" style="margin-top:10px">
          <button id="sumBtn">요약 실행</button>
          <button id="sumCopyBtn" class="secondary">결과 복사</button>
        </div>

        <div id="sumStatus" class="status muted">대기 중</div>
        <div id="sumOutput" class="out" style="margin-top:10px"></div>
      </div>

      <div class="card">
        <h2>🎨 이미지 생성</h2>

        <label for="imgPrompt">프롬프트</label>
        <textarea id="imgPrompt" placeholder="예) futuristic library in Seoul at night, cinematic lighting, ultra detailed"></textarea>

        <div class="row">
          <div>
            <label for="imgSize">사이즈</label>
            <select id="imgSize">
              <option value="1024x1024">1024x1024</option>
              <option value="1024x1536">1024x1536</option>
              <option value="1536x1024">1536x1024</option>
            </select>
          </div>
          <div>
            <label for="imgQuality">퀄리티</label>
            <select id="imgQuality">
              <option value="high">high</option>
              <option value="medium">medium</option>
              <option value="low">low</option>
            </select>
          </div>
        </div>

        <div class="row" style="margin-top:10px">
          <button id="imgBtn">이미지 생성</button>
          <button id="imgDownloadBtn" class="secondary">첫 이미지 다운로드</button>
        </div>

        <div id="imgStatus" class="status muted">대기 중</div>
        <div id="imgOutput" class="img-wrap" style="margin-top:10px"></div>
      </div>
    </div>
  </div>

  <script>
    // ★ 본인 Cloudflare Worker URL로 바꾸세요
    const PROXY_URL = "https://aiverse-proxy.yourname.workers.dev";

    const $ = (id) => document.getElementById(id);

    const sumModeEl = $("sumMode");
    const sumInputEl = $("sumInput");
    const sumBtn = $("sumBtn");
    const sumCopyBtn = $("sumCopyBtn");
    const sumStatusEl = $("sumStatus");
    const sumOutputEl = $("sumOutput");

    const imgPromptEl = $("imgPrompt");
    const imgSizeEl = $("imgSize");
    const imgQualityEl = $("imgQuality");
    const imgBtn = $("imgBtn");
    const imgDownloadBtn = $("imgDownloadBtn");
    const imgStatusEl = $("imgStatus");
    const imgOutputEl = $("imgOutput");

    let lastImageUrl = "";

    async function callResponsesAPI(body) {
      const res = await fetch(PROXY_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body)
      });

      if (!res.ok) {
        const t = await res.text();
        throw new Error(`API 오류 (${res.status}): ${t}`);
      }
      return res.json();
    }

    function extractTextFromResponse(data) {
      if (data.output_text) return data.output_text;
      const chunks = [];
      (data.output || []).forEach(item => {
        (item.content || []).forEach(c => {
          if ((c.type === "output_text" || c.type === "text") && c.text) chunks.push(c.text);
        });
      });
      return chunks.join("\n").trim();
    }

    function extractImageUrlsFromResponse(data) {
      const urls = [];
      (data.output || []).forEach(item => {
        (item.content || []).forEach(c => {
          if ((c.type === "image" || c.type === "output_image") && c.url) urls.push(c.url);
        });
      });
      return urls;
    }

    // 요약
    sumBtn.addEventListener("click", async () => {
      const text = sumInputEl.value.trim();
      if (!text) {
        sumStatusEl.textContent = "요약할 텍스트를 입력하세요.";
        sumStatusEl.className = "status warn";
        return;
      }

      const mode = sumModeEl.value;
      const modePrompt = {
        short: "다음 텍스트를 5문장 이내로 요약해줘.",
        bullet: "다음 텍스트를 핵심 bullet 7개 이내로 정리해줘. 중요한 단어는 굵게.",
        report: "다음 텍스트를 [배경]-[핵심]-[시사점]-[실행 항목] 형식으로 정리해줘."
      }[mode];

      sumBtn.disabled = true;
      sumStatusEl.textContent = "요약 생성 중...";
      sumStatusEl.className = "status";
      sumOutputEl.textContent = "";

      try {
        const data = await callResponsesAPI({
          model: "gpt-4.1-mini",
          input: [
            { role: "system", content: "너는 한국어 문서 요약 전문가다. 간결하고 정확하게 작성한다." },
            { role: "user", content: `${modePrompt}\n\n원문:\n${text}` }
          ]
        });

        sumOutputEl.textContent = extractTextFromResponse(data) || "결과를 읽지 못했습니다.";
        sumStatusEl.textContent = "완료";
        sumStatusEl.className = "status ok";
      } catch (e) {
        sumOutputEl.textContent = e.message;
        sumStatusEl.textContent = "실패";
        sumStatusEl.className = "status warn";
      } finally {
        sumBtn.disabled = false;
      }
    });

    sumCopyBtn.addEventListener("click", async () => {
      const text = sumOutputEl.textContent.trim();
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        sumStatusEl.textContent = "복사 완료";
        sumStatusEl.className = "status ok";
      } catch {
        sumStatusEl.textContent = "복사 실패";
        sumStatusEl.className = "status warn";
      }
    });

    // 이미지
    imgBtn.addEventListener("click", async () => {
      const prompt = imgPromptEl.value.trim();
      if (!prompt) {
        imgStatusEl.textContent = "프롬프트를 입력하세요.";
        imgStatusEl.className = "status warn";
        return;
      }

      imgBtn.disabled = true;
      imgStatusEl.textContent = "이미지 생성 중...";
      imgStatusEl.className = "status";
      imgOutputEl.innerHTML = "";
      lastImageUrl = "";

      try {
        const data = await callResponsesAPI({
          model: "gpt-4.1",
          input: prompt,
          tools: [{
            type: "image_generation",
            size: imgSizeEl.value,
            quality: imgQualityEl.value
          }]
        });

        const urls = extractImageUrlsFromResponse(data);
        if (!urls.length) {
          imgOutputEl.textContent = JSON.stringify(data, null, 2);
          imgStatusEl.textContent = "이미지 URL을 찾지 못했습니다.";
          imgStatusEl.className = "status warn";
          return;
        }

        urls.forEach((url, i) => {
          const img = document.createElement("img");
          img.src = url;
          img.alt = `generated-${i+1}`;
          img.loading = "lazy";
          imgOutputEl.appendChild(img);
        });

        lastImageUrl = urls[0];
        imgStatusEl.textContent = `완료 (${urls.length}장)`;
        imgStatusEl.className = "status ok";
      } catch (e) {
        imgOutputEl.textContent = e.message;
        imgStatusEl.textContent = "실패";
        imgStatusEl.className = "status warn";
      } finally {
        imgBtn.disabled = false;
      }
    });

    imgDownloadBtn.addEventListener("click", () => {
      if (!lastImageUrl) {
        imgStatusEl.textContent = "먼저 이미지를 생성하세요.";
        imgStatusEl.className = "status warn";
        return;
      }
      const a = document.createElement("a");
      a.href = lastImageUrl;
      a.download = "aiverse-image.png";
      a.target = "_blank";
      a.click();
    });
  </script>
</body>
</html>
