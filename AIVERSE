    function renderProjects() {
      var arr = JSON.parse(localStorage.getItem("aiverse") || "[]");
      var box = document.getElementById("projectList");

      if (arr.length === 0) {
        box.innerHTML = '<div class="result">저장된 프로젝트가 없습니다.</div>';
        return;
      }

      box.innerHTML = arr.map(function(p) {
        return `
          <div class="project">
            <b>${escapeHtml(p.type)} · ${escapeHtml(p.title)}</b><br>
            <small>${escapeHtml(p.date)}</small>
            <p>${escapeHtml(p.content.slice(0, 250))}${p.content.length > 250 ? "..." : ""}</p>
          </div>
        `;
      }).join("");
    }

    function clearProjects() {
      if (confirm("전체 삭제할까요?")) {
        localStorage.removeItem("aiverse");
        renderProjects();
      }
    }

    function escapeHtml(text) {
      return String(text).replace(/[&<>"']/g, function(match) {
        return {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#039;"
        }[match];
      });
    }

